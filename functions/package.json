{
  "name": "@propwise/functions",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "deploy": "firebase deploy --only functions",
    "test": "jest",
    "test:evals": "jest --config jest.eval.config.js --testPathPattern level1-mocked",
    "test:evals:live": "ts-node src/evals/gate.ts",
    "test:evals:live:yes": "EVALS_LIVE=1 ts-node src/evals/gate.ts",
    "test:evals:level2": "jest --config jest.eval.config.js --testPathPattern level2",
    "test:evals:alignment": "ts-node src/evals/runners/alignment.ts",
    "test:all": "jest && jest --config jest.eval.config.js --testPathPattern level1-mocked"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@google/genai": "^1.42.0",
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^7.0.5",
    "grammy": "^1.41.1",
    "resend": "^6.9.2",
    "stripe": "^16.0.0",
    "svix": "^1.84.1",
    "twilio": "^5.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "dotenv": "^17.3.1",
    "firebase-functions-test": "^3.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": "22"
  }
}
