rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: get the authenticated user's organizationId from the users collection
    function getUserOrg() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.organizationId;
    }

    // Deny all access by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Users collection: authenticated users can read their own document
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Organizations: authenticated users can only access their own organization
    match /organizations/{orgId} {
      allow read: if request.auth != null && getUserOrg() == orgId;
      allow write: if request.auth != null && getUserOrg() == orgId;
    }

    // Properties: scoped to the user's organization
    match /properties/{propertyId} {
      allow read: if request.auth != null && getUserOrg() == resource.data.organizationId;
      allow create: if request.auth != null && getUserOrg() == request.resource.data.organizationId;
      allow update, delete: if request.auth != null && getUserOrg() == resource.data.organizationId;
    }

    // Units: scoped to the user's organization
    match /units/{unitId} {
      allow read: if request.auth != null && getUserOrg() == resource.data.organizationId;
      allow create: if request.auth != null && getUserOrg() == request.resource.data.organizationId;
      allow update, delete: if request.auth != null && getUserOrg() == resource.data.organizationId;
    }

    // Tenants: scoped to the user's organization
    match /tenants/{tenantId} {
      allow read: if request.auth != null && getUserOrg() == resource.data.organizationId;
      allow create: if request.auth != null && getUserOrg() == request.resource.data.organizationId;
      allow update, delete: if request.auth != null && getUserOrg() == resource.data.organizationId;
    }

    // Conversations: scoped to the user's organization
    match /conversations/{conversationId} {
      allow read: if request.auth != null && getUserOrg() == resource.data.organizationId;
      allow create: if request.auth != null && getUserOrg() == request.resource.data.organizationId;
      allow update, delete: if request.auth != null && getUserOrg() == resource.data.organizationId;
    }

    // Messages: scoped to the user's organization
    match /messages/{messageId} {
      allow read: if request.auth != null && getUserOrg() == resource.data.organizationId;
      allow create: if request.auth != null && getUserOrg() == request.resource.data.organizationId;
      allow update, delete: if request.auth != null && getUserOrg() == resource.data.organizationId;
    }

    // Work Orders: scoped to the user's organization
    match /workOrders/{workOrderId} {
      allow read: if request.auth != null && getUserOrg() == resource.data.organizationId;
      allow create: if request.auth != null && getUserOrg() == request.resource.data.organizationId;
      allow update, delete: if request.auth != null && getUserOrg() == resource.data.organizationId;
    }

    // Vendors: scoped to the user's organization
    match /vendors/{vendorId} {
      allow read: if request.auth != null && getUserOrg() == resource.data.organizationId;
      allow create: if request.auth != null && getUserOrg() == request.resource.data.organizationId;
      allow update, delete: if request.auth != null && getUserOrg() == resource.data.organizationId;
    }

    // Knowledge Base: scoped to the user's organization
    match /knowledgeBase/{docId} {
      allow read: if request.auth != null && getUserOrg() == resource.data.organizationId;
      allow create: if request.auth != null && getUserOrg() == request.resource.data.organizationId;
      allow update, delete: if request.auth != null && getUserOrg() == resource.data.organizationId;
    }

    // Marketing collections: admin SDK only (all client access through callable functions)
    match /leads/{docId} {
      allow read, write: if false;
    }
    match /emailSequences/{docId} {
      allow read, write: if false;
    }
    match /emailEvents/{docId} {
      allow read, write: if false;
    }
    match /socialPosts/{docId} {
      allow read, write: if false;
    }
    match /campaigns/{docId} {
      allow read, write: if false;
    }
    match /marketingSettings/{docId} {
      allow read, write: if false;
    }
  }
}
